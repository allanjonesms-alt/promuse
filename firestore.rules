rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email != null &&
             (
               request.auth.token.email.lower() == 'allanjonesms@gmail.com' ||
               exists(
                 /databases/$(database)/documents/admins/$(request.auth.token.email.lower())
               )
             );
		}

    function isMaster() {
      return request.auth != null &&
             request.auth.token.email != null &&
             (
               request.auth.token.email.lower() == 'allanjonesms@gmail.com' ||
               (exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())) &&
                get(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())).data.role == 'master')
             );
    }

    match /admins/{adminId} {
        allow get: if isSignedIn();
        allow list: if isAdmin();
        allow create: if isMaster() && isValidId(adminId);
        allow update: if isMaster();
        allow delete: if isMaster() && isValidId(adminId);
    }

    function isValidId(id) { 
        return id is string && id.size() <= 128; 
    }

    match /victims/{victimId} {
        allow list: if isAdmin();
        allow get: if isAdmin() && isValidId(victimId);
        allow create: if isAdmin() && isValidId(victimId);
        allow update: if isAdmin() && isValidId(victimId);
        allow delete: if isAdmin() && isValidId(victimId);
    }

    match /panicAlerts/{alertId} {
        allow list: if isAdmin();
        allow get: if isAdmin() && isValidId(alertId);
        allow create: if isValidId(alertId); 
        allow update: if isAdmin() && isValidId(alertId);
        allow delete: if isAdmin() && isValidId(alertId);
    }

    match /occurrences/{occurrenceId} {
        allow list: if isAdmin();
        allow get: if isAdmin() && isValidId(occurrenceId);
        allow create: if isAdmin() && isValidId(occurrenceId);
        allow update: if isAdmin() && isValidId(occurrenceId);
        allow delete: if isAdmin() && isValidId(occurrenceId);
    }

    match /hearings/{hearingId} {
        allow list: if isAdmin();
        allow get: if isAdmin() && isValidId(hearingId);
        allow create: if isAdmin() && isValidId(hearingId);
        allow update: if isAdmin() && isValidId(hearingId);
        allow delete: if isAdmin() && isValidId(hearingId);
    }
  }
}